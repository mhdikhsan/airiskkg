@prefix mit:   <http://w3id.org/airiskkg/taxonomy/mit-ai-risk#> .
@prefix nexus: <http://w3id.org/airiskkg/taxonomy/nexus#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# Ontology declaration
#################################################################

<http://w3id.org/airiskkg/taxonomy/mit-ai-risk#> a owl:Ontology ;
    rdfs:label "MIT AI Risk Repository Subset for AI Risk KG" ;
    dct:title "MIT AI Risk Repository Subset for AI Risk KG" ;
    dct:description """
    A selected RDF subset of the MIT AI Risk Repository domain taxonomy,
    adapted from AI Atlas Nexus for use in graph-pattern-based AI risk assessment.
    """ ;
    dct:source <https://github.com/IBM/ai-atlas-nexus/blob/main/src/ai_atlas_nexus/data/knowledge_graph/mit_ai_risk_repository_data.yaml> .

#################################################################
# Taxonomy
#################################################################

mit:MIT_AI_Risk_Repository_Domain_Taxonomy a nexus:RiskTaxonomy, skos:ConceptScheme ;
    skos:prefLabel "MIT AI Risk Repository: Domain Taxonomy of AI Risks" ;
    dct:description "A domain taxonomy of AI risks organized into high-level AI risk domains and subdomains." .

#################################################################
# Domains
#################################################################

mit:domain-1 a nexus:RiskGroup ;
    skos:prefLabel "Discrimination & Toxicity" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-2 a nexus:RiskGroup ;
    skos:prefLabel "Privacy & Security" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-3 a nexus:RiskGroup ;
    skos:prefLabel "Misinformation" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-4 a nexus:RiskGroup ;
    skos:prefLabel "Malicious Actors & Misuse" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-5 a nexus:RiskGroup ;
    skos:prefLabel "Human-Computer Interaction" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-6 a nexus:RiskGroup ;
    skos:prefLabel "Socioeconomic & Environmental" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

mit:domain-7 a nexus:RiskGroup ;
    skos:prefLabel "AI System Safety, Failures, & Limitations" ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    skos:topConceptOf mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy .

#################################################################
# Selected subdomains
#################################################################

mit:subdomain-1-1 a nexus:Risk ;
    skos:prefLabel "Unfair discrimination and misrepresentation" ;
    skos:definition "AI may treat individuals or groups unfairly or represent them in harmful ways." ;
    skos:broader mit:domain-1 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-1 .

mit:subdomain-1-2 a nexus:Risk ;
    skos:prefLabel "Exposure to toxic content" ;
    skos:definition "AI may expose users to harmful, abusive, unsafe, or inappropriate content." ;
    skos:broader mit:domain-1 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-1 .

mit:subdomain-1-3 a nexus:Risk ;
    skos:prefLabel "Unequal performance across groups" ;
    skos:definition "AI system performance may differ across demographic or social groups." ;
    skos:broader mit:domain-1 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-1 .

mit:subdomain-2-1 a nexus:Risk ;
    skos:prefLabel "Compromise of privacy by obtaining, leaking or inferring sensitive information" ;
    skos:definition "AI systems may leak, infer, or expose sensitive information about individuals or organizations." ;
    skos:broader mit:domain-2 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-2 .

mit:subdomain-2-2 a nexus:Risk ;
    skos:prefLabel "AI system security vulnerabilities and attacks" ;
    skos:definition "AI systems may contain vulnerabilities that enable unauthorized access, manipulation, or unsafe behavior." ;
    skos:broader mit:domain-2 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-2 .

mit:subdomain-3-1 a nexus:Risk ;
    skos:prefLabel "False or misleading information" ;
    skos:definition "AI systems may generate or spread incorrect, deceptive, or misleading information." ;
    skos:broader mit:domain-3 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-3 .

mit:subdomain-4-3 a nexus:Risk ;
    skos:prefLabel "Fraud, scams, and targeted manipulation" ;
    skos:definition "AI systems may be used to manipulate, deceive, impersonate, or exploit people." ;
    skos:broader mit:domain-4 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-4 .

mit:subdomain-5-1 a nexus:Risk ;
    skos:prefLabel "Overreliance and unsafe use" ;
    skos:definition "Users may place inappropriate trust in AI systems or use them unsafely." ;
    skos:broader mit:domain-5 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-5 .

mit:subdomain-5-2 a nexus:Risk ;
    skos:prefLabel "Loss of human agency and autonomy" ;
    skos:definition "AI systems may reduce human control, agency, or autonomy in decision-making." ;
    skos:broader mit:domain-5 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-5 .

mit:subdomain-6-6 a nexus:Risk ;
    skos:prefLabel "Environmental harm" ;
    skos:definition "AI development or operation may contribute to environmental harm through resource use or emissions." ;
    skos:broader mit:domain-6 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-6 .

mit:subdomain-7-3 a nexus:Risk ;
    skos:prefLabel "Lack of capability or robustness" ;
    skos:definition "AI systems may fail to perform reliably or effectively under varying conditions." ;
    skos:broader mit:domain-7 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-7 .

mit:subdomain-7-4 a nexus:Risk ;
    skos:prefLabel "Lack of transparency or interpretability" ;
    skos:definition "AI systems may be difficult to understand, explain, audit, or correct." ;
    skos:broader mit:domain-7 ;
    skos:inScheme mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isDefinedByTaxonomy mit:MIT_AI_Risk_Repository_Domain_Taxonomy ;
    nexus:isPartOf mit:domain-7 .